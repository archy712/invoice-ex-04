# Notion API (견적서 원본 데이터 조회)
# https://www.notion.so/my-integrations 에서 Integration 생성 후 발급
NOTION_API_KEY=secret_xxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxx

# Supabase (Auth + PostgreSQL, 견적서/품목 캐시 저장용)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxx
